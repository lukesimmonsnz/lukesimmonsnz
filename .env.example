# Local-only env vars (gitignored as .env). Copy this file to ".env"
# and fill in the values. The agent and the publish scripts read .env
# at startup; real OS env vars take precedence.

# ---------------------------------------------------------------------
# Weekly digest review email — sent by agent/weekly_post.py after the
# draft is written, so Luke can scan it on phone/desktop and decide.
# ---------------------------------------------------------------------

# Resend account API key. Same key as the Cloudflare Pages env var.
# Leave blank to skip the review email entirely (the draft will still
# be written locally with status=draft).
RESEND_API_KEY=

# Verified Resend sender. Must match the domain you verified on Resend.
CONTACT_FROM=form@lukesimmonsnz.kiwi

# Where review emails go. Use the +form Gmail alias or your forwarder.
CONTACT_TO=lukesimmonsnz+form@gmail.com

# ---------------------------------------------------------------------
# Cloudflare Pages deploy — used by scripts/deploy.bat and
# scripts/publish_weekly.bat. Already documented in docs/CLOUDFLARE-DEPLOY.md.
# ---------------------------------------------------------------------

SITE_URL=https://lukesimmonsnz.kiwi
CONTACT_SUBMIT_URL=/api/contact
TURNSTILE_SITE_KEY=0x4AAAAAADCRtescIooaJl01
