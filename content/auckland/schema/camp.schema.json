{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aucklandproject://schema/camp.schema.json",
  "title": "Camp",
  "description": "A cluster of proposed solutions sharing a core claim. Camps are presented neutrally alongside each other.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "core_claim", "flagship_moves", "tensions", "addresses", "interventions"],
  "properties": {
    "id": {"type": "string", "pattern": "^camp\\.[a-z0-9_.]+$"},
    "name": {"type": "string"},
    "core_claim": {"type": "string"},
    "flagship_moves": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "tensions": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "addresses": {"type": "array", "items": {"type": "string", "pattern": "^problem\\."}, "minItems": 1},
    "interventions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description"],
        "properties": {
          "description": {"type": "string"},
          "state_variable": {"type": "string"},
          "constraint_relaxed": {"type": "string"},
          "expected_sign": {"enum": ["+", "-", "0", "?"]},
          "side_effects": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "advocates": {"type": "array", "items": {"type": "string"}},
    "evidence_ids": {"type": "array", "items": {"type": "string", "pattern": "^evidence\\."}},
    "tensions_with": {"type": "array", "items": {"type": "string", "pattern": "^camp\\."}}
  }
}
