{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aucklandproject://schema/problem.schema.json",
  "title": "Problem",
  "description": "A named issue or subpage within a domain. Pages are rendered from Problem entities.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "section", "subpage", "summary", "systems_model", "narrative", "driver_ids", "camp_ids", "evidence_ids", "source_ids", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^problem\\.[a-z0-9_.]+$"
    },
    "title": {"type": "string"},
    "section": {"type": "string"},
    "subpage": {"type": "string"},
    "parent": {"type": ["string", "null"]},
    "order": {"type": "integer"},
    "updated": {"type": "string", "format": "date"},
    "summary": {"type": "string"},
    "systems_model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state_variables", "inputs", "constraints", "feedback_loops"],
      "properties": {
        "state_variables": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "inputs": {"type": "array", "items": {"type": "string"}},
        "constraints": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "feedback_loops": {"type": "array", "items": {"type": "string"}}
      }
    },
    "narrative": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["heading", "body"],
        "properties": {
          "heading": {"type": "string"},
          "body": {"type": "string"},
          "figure": {"type": "string"}
        }
      }
    },
    "figures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "caption"],
        "properties": {
          "id": {"type": "string"},
          "caption": {"type": "string"},
          "image": {"type": "string"},
          "alt": {"type": "string"},
          "status": {"enum": ["placeholder", "draft", "final"]}
        }
      }
    },
    "driver_ids": {"type": "array", "items": {"type": "string", "pattern": "^driver\\."}, "minItems": 1},
    "camp_ids": {"type": "array", "items": {"type": "string", "pattern": "^camp\\."}, "minItems": 1},
    "evidence_ids": {"type": "array", "items": {"type": "string", "pattern": "^evidence\\."}, "minItems": 1},
    "response_ids": {"type": "array", "items": {"type": "string", "pattern": "^response\\."}},
    "source_ids": {"type": "array", "items": {"type": "string", "pattern": "^source\\."}, "minItems": 1},
    "status": {"enum": ["draft-v0", "draft", "review", "published"]}
  }
}
